# ============================================
# Configuración PERN Stack con Docker Compose
# ============================================
# NOTA: Los valores por defecto ya están en docker-compose.yml
# Este archivo es una referencia si necesitas customizar las variables

# Nombres de los contenedores
MARIADB_CONTAINER_NAME=taller_mariadb
BACKEND_CONTAINER_NAME=pern_backend
FRONTEND_CONTAINER_NAME=pern_frontend

# ============================================
# MariaDB Database
# ============================================
DB_NAME=taller_db
DB_USER=taller_user
DB_PASSWORD=taller_password
DB_ROOT_PASSWORD=root_root_password
DB_PORT=3306

# ============================================
# Backend (Node.js + Express)
# ============================================
NODE_ENV=production
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=taller_db
DB_USER=taller_user
DB_PASSWORD=taller_password
API_PORT=5000
JWT_SECRET=taller_jwt_secret_key_12345

# ============================================
# Frontend (React + Nginx)
# ============================================
REACT_APP_API_URL=http://backend:5000
FRONTEND_PORT=5173
