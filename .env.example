# ============================================
# Configuración PERN Stack con Docker Compose
# ============================================
# NOTA: Los valores por defecto ya están en docker-compose.yml
# Este archivo es una referencia si necesitas customizar las variables

# Nombres de los contenedores
MARIADB_CONTAINER_NAME=XXXX
BACKEND_CONTAINER_NAME=XXXX
FRONTEND_CONTAINER_NAME=XXXX

# ============================================
# MariaDB Database
# ============================================
DB_NAME=XXXX
DB_USER=XXXX
DB_PASSWORD=XXXX
DB_ROOT_PASSWORD=XXXX
DB_PORT=3306

# ============================================
# Backend (Node.js + Express)
# ============================================
NODE_ENV=production
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=XXXX
DB_USER=XXXX
DB_PASSWORD=XXXX
API_PORT=5000
JWT_SECRET=//tu clave

# ============================================
# Frontend (React + Nginx)
# ============================================
# Dejar vacío para usar /api desde el mismo origen del frontend
REACT_APP_API_URL=
API_URL=
FRONTEND_PORT=5173
